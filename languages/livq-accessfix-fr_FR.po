#, php-format
msgid ""
"Heading hierarchy skip: found <h%1$d> right after <h%2$d> without a <h%3$d> "
"in between. This disorients screen reader users navigating by headings (WCAG "
"1.3.1)."
msgstr ""
"Saut de hiérarchie de titres : balise <h%1$d> trouvée juste après <h%2$d> "
"sans <h%3$d> intermédiaire. Cela désactive les utilisateurs de lecteurs "
"d'écran qui naviguent par titres (WCAG 1.3.1)."

