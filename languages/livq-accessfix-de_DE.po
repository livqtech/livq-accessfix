msgid "Add %s to cart"
msgstr "%s in den Warenkorb legen"

#: includes/class-edg-woocommerce.php:254
msgid "added to cart."
msgstr "zum Warenkorb hinzugefügt."

#: includes/class-edg-woocommerce.php:255
msgid "Item added to cart."
msgstr "Artikel zum Warenkorb hinzugefügt."

#: includes/class-edg-woocommerce.php:256
msgid "Item removed from cart."
msgstr "Artikel aus dem Warenkorb entfernt."

#: includes/class-edg-woocommerce.php:257
msgid "Quantity"
msgstr "Menge"

