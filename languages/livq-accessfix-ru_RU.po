msgstr "Настроить и просмотреть заявление →"

#: includes/class-edg-backend.php:890
msgid "Activate the [edg_accessibility_statement] shortcode"
msgstr "Активируйте шорткод [edg_accessibility_statement]"

#: includes/class-edg-backend.php:893
